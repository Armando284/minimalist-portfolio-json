---
import { basics } from '@cv'

interface Props {
	title: string
}

const { title } = Astro.props

const { image, summary, url } = basics
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta
			name="description"
			content={summary}
		/>
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="preload"
			as="image"
			href={image}
		/>

		<meta
			property="og:url"
			content={url}
		/>
		<meta
			property="og:type"
			content="website"
		/>
		<meta
			property="og:title"
			content={title}
		/>
		<meta
			property="og:description"
			content={summary}
		/>
		<meta
			property="og:image"
			content=""
		/>

		<meta
			name="twitter:card"
			content="summary_large_image"
		/>
		<meta
			property="twitter:domain"
			content={url.split('//')[1] ?? ''}
		/>
		<meta
			property="twitter:url"
			content={url}
		/>
		<meta
			name="twitter:title"
			content={title}
		/>
		<meta
			name="twitter:description"
			content={summary}
		/>
		<meta
			name="twitter:image"
			content=""
		/>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
    /* Palette Fiery Ocean https://coolors.co/palette/780000-c1121f-fdf0d5-003049-669bbc */
		--color-custom-blue-300: #669bbc;
		--color-custom-blue-700: #003049;
		--color-custom-red-50: #fdf0d5;
		--color-custom-red-600: #c1121f;
		--color-custom-red-800: #780000;

    /* Palette Deep Sea https://coolors.co/palette/0d1b2a-1b263b-415a77-778da9-e0e1dd */
    --color-deep-sea-50: #e0e1dd;
    --color-deep-sea-300: #778da9;
    --color-deep-sea-500: #415a77;
    --color-deep-sea-700: #1b263b;
    --color-deep-sea-900: #0d1b2a;

		--hero-card-height: 164px;
    --color-tag-color: var(--color-deep-sea-500);
    --color-tag-backround: var(--color-deep-sea-50);
	}

	html {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			'Courier New',
			Courier,
			monospace;
		background: #fff;
    color: var(--color-deep-sea-500);
		letter-spacing: -0.025rem;
	}

	body,
	figure {
		margin: 0;
		padding: 0;
	}

	a {
		text-decoration: none;
	}

	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	h1,
	h2,
	h3,
	h4,
	h5,
	h6 {
		margin: 0;
		font-family:
			system-ui,
			-apple-system,
			BlinkMacSystemFont,
			'Segoe UI',
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			'Open Sans',
			'Helvetica Neue',
			sans-serif;
		color: var(--color-deep-sea-900);
	}

  h1 {
    font-size: 2.5rem;
    text-wrap: balance;
    font-weight: 900;
  }

  h2 {
    font-size: 1.75rem;
    text-wrap: balance;
    font-weight: 700;
  }

  h3 {
    font-size: 1.5rem;
    text-wrap: balance;
    font-weight: 700;
  }
  h4 {
    font-size: 1.25rem;
    text-wrap: balance;
    font-weight: 500;
  }
  h5 {
    font-size: 1.1rem;
    text-wrap: balance;
    font-weight: 500;
  }
  h6 {
    font-size: 1rem;
    text-wrap: balance;
    font-weight: 500;
  }
  
	p {
		color: var(--color-deep-sea-500);
		font-size: 0.9rem;
		line-height: 1.5;
		margin: 0;
		text-wrap: pretty;
	}

  .tag{
    max-width: fit-content;
    display: inline-block;
    color: var(--color-tag-color);
    background-color: var(--color-tag-backround);
    padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: 0.75rem;
    margin-right: 4px;
  }

	.print {
		display: none !important;
	}

	@media print {
		.no-print {
			display: none !important;
		}

		.print {
			display: block !important;
		}

		astro-dev-toolbar {
			display: none !important;
		}

		article {
			break-inside: avoid;
		}
	}
</style>
