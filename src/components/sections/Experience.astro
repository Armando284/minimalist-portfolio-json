---
import Section from '../Section.astro'

import { work } from '@cv'
---

<Section title="Experience">
	<ul>
		{
			work.map(
				({
					name,
					startDate,
					endDate,
					position,
					summary,
					highlights,
					url,
				}) => {
					const startYear = new Date(startDate).getFullYear()
					const endYear =
						endDate != null
							? new Date(endDate).getFullYear()
							: 'Actual'

					return (
						<li>
							<article>
								<header>
									<div>
										<h2>
											<a
												href={url}
												title={`Ver ${name}`}
												target="_blank">
												{name}
											</a>
										</h2>
                    <h4>{position}</h4>
									</div>

									<div>
										<time
											datetime={startDate}
											data-title={startDate}>
											{startYear}
										</time>
										{' - '}
										<time
											datetime={endDate}
											data-title={endDate}>
											{endYear}
										</time>
									</div>
								</header>
									<p>{summary}</p>
								<footer>
                  {highlights.length > 0 && (
                        highlights.map((h) => (
                          <span
                            class="tag"
                            >
                            {h}
                          </span>
                        ))
                      )}
								</footer>
							</article>
						</li>
					)
				}
			)
		}
	</ul>
</Section>

<style>
	ul {
		display: flex;
		flex-direction: column;
		gap: 32px;
	}

	article a {
		color: var(--color-custom-blue-700);
		font-weight: 600;
	}

	article a:hover {
		text-decoration: underline;
	}

	header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 8px;
	}

	footer {
		display: flex;
		gap: 8px;
	}
	article footer h4 {
		font-weight: 600;
	}

	time {
		font-size: 0.85rem;
		min-width: 102px;
		cursor: default;
	}

	[data-title]:hover:after {
		opacity: 1;
		transition: all 0.1s ease-in-out 0.5s;
		visibility: visible;
	}

	[data-title]:after {
		content: attr(data-title);
		background-color: var(--color-deep-sea-900);
		color: var(--color-deep-sea-50);
		font-size: 0.75rem;
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			'Courier New',
			monospace;
		position: absolute;
		padding: 0.2rem 0.5rem;
		bottom: -1.4rem;
		left: 50%;
		white-space: nowrap;
		box-shadow: 1px 1px 1px var(--color-deep-sea-300);
		opacity: 0;
		border: 1px solid var(--color-deep-sea-300);
		z-index: 99999;
		visibility: hidden;
		border-radius: 6px;
	}

	[data-title] {
		position: relative;
	}

  
</style>
